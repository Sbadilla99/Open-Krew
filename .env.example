# OpenKrew — Config
# Copy this file as .env and fill in your keys

# REQUIRED — Your Telegram bot token
TELEGRAM_BOT_TOKEN=

# YOUR KREW — Add the ones you want
ANTHROPIC_API_KEY=       # Claude  → console.anthropic.com
OPENAI_API_KEY=          # ChatGPT → platform.openai.com/api-keys
GEMINI_API_KEY=          # Gemini  → aistudio.google.com/app/apikey
